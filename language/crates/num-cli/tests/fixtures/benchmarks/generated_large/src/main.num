module benchmarks.generated_large

type AccountId = Brand<Text, "AccountId">

type AccountEvent {
    id: AccountId from UserInput internal
    amount: Money<KZT> from UserInput internal
    accepted: Bool from UserInput internal
}

fn accept_event(event: AccountEvent) -> Bool {
    audit("accept_event", {
        id: event.id,
        amount: event.amount
    })
    return event.accepted
}

workflow generated_001(event: AccountEvent) {
    let accepted: Bool = accept_event(event)
    assert accepted == true
}
