// Generated by num deploy for billing 1.2.3.
// Required Jenkins runtime: num CLI on PATH and repository checkout access.
// Required parameters: NUM_PROJECT_DIR and NUM_DEPLOY_DIR.
// Secret values stay in Jenkins credentials or an external secret store; if
// [deployment].credentials_ref is set, map it to NUM_REGISTRY_CREDENTIALS_ID
// without committing the underlying credential value.
pipeline {
  agent any

  options {
    timestamps()
  }

  parameters {
    string(name: 'NUM_PROJECT_DIR', defaultValue: '.', description: 'Num project directory or entry file to validate and package')
    string(name: 'NUM_DEPLOY_DIR', defaultValue: 'dist/num-deploy', description: 'Deployment bundle output directory')
    string(name: 'NUM_REGISTRY_CREDENTIALS_ID', defaultValue: '', description: 'Optional Jenkins credentials id matching [deployment].credentials_ref')
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Policy gate') {
      steps {
        sh 'num check "$NUM_PROJECT_DIR"'
        sh 'num test "$NUM_PROJECT_DIR"'
      }
    }

    stage('Cost gate') {
      steps {
        sh 'num cost-report "$NUM_PROJECT_DIR" --json > num-cost-report.json'
      }
    }

    stage('Security gate') {
      steps {
        sh 'num lint "$NUM_PROJECT_DIR"'
      }
    }

    stage('Deploy artifact') {
      steps {
        sh 'num deploy "$NUM_PROJECT_DIR" --apply --replace --dir "$NUM_DEPLOY_DIR" --json > num-deploy.json'
      }
    }
  }

  post {
    always {
      archiveArtifacts artifacts: 'num-cost-report.json,num-deploy.json,dist/num-deploy/**', allowEmptyArchive: true
    }
  }
}
