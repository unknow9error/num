{
  "openapi": "3.0.0",
  "info": {
    "title": "Customer Portal",
    "version": "1.0.0"
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "UpdateCustomerRequest": {
        "type": "object",
        "properties": {
          "customer_email": {
            "type": "string",
            "format": "email"
          },
          "tenant_id": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          }
        }
      },
      "CustomerProfile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          }
        }
      }
    }
  },
  "paths": {
    "/customers/{customer_id}": {
      "patch": {
        "operationId": "update_customer",
        "tags": [
          "customers"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "customer_id",
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateCustomerRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CustomerProfile"
                }
              }
            }
          }
        }
      }
    }
  }
}
